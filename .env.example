AIS_DATABASE_URL=sqlite:///./var/agentic_image_sourcing.db
AIS_LOCAL_CACHE_DIR=./var/cache
AIS_LOCAL_OBJECT_STORE_DIR=./var/object-store
AIS_OBJECT_STORE_BACKEND=local
AIS_GOOGLE_API_KEY=
AIS_GOOGLE_CSE_ID=
AIS_PINCHTAB_BASE_URL=http://127.0.0.1:9867
AIS_PINCHTAB_TOKEN=
AIS_PINCHTAB_DEFAULT_BROWSER_MODE=headed
AIS_PINCHTAB_GALLERY_SCROLL_STEP=1200
AIS_PINCHTAB_GALLERY_SCROLL_ATTEMPTS=8
AIS_PINCHTAB_SCROLL_PAUSE_SECONDS=1.0
AIS_GOOGLE_GALLERY_POOL_MULTIPLIER=3
AIS_CRAWL_RESPECT_ROBOTS=true
AIS_ENABLE_BROWSER_CAPTURE=false
AIS_RATE_LIMIT_PER_DOMAIN_SECONDS=1.0
